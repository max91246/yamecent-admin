            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "account",
                  "value": "testuser",
                  "description": "帳號（必填，需唯一）",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "secret123",
                  "description": "密碼（必填）",
                  "type": "text"
                },
                {
                  "key": "nickname",
                  "value": "測試用戶",
                  "description": "暱稱（必填）",
