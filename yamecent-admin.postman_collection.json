            "url": {
              "raw": "{{base_url}}/members/register",
              "host": ["{{base_url}}"],
              "path": ["members", "register"]
            },
            "description": "註冊新會員，支援同時上傳頭像。**不需要 Token**\n\n必填：account、password、nickname\n選填：email、phone、avatar（圖片檔案）\n\n注意：\n- 密碼以 bcrypt 加密儲存，回傳不含密碼\n- 帳號重複回傳 code 409\n- 頭像格式限 jpg/png/gif，大小限 5MB"
          },
          "response": [
            {
              "name": "註冊成功",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 200,\n  \"msg\": \"success\",\n  \"data\": {\n    \"id\": 1,\n    \"account\": \"testuser\",\n    \"avatar\": \"/uploads/avatar/20260324/abc123.jpg\",\n    \"nickname\": \"測試用戶\",\n    \"email\": \"test@example.com\",\n    \"phone\": \"0912345678\",\n    \"is_active\": 1,\n    \"created_at\": \"2026-03-24T00:00:00.000000Z\"\n  }\n}"
            },
            {
              "name": "帳號已存在",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 409,\n  \"msg\": \"帳號已存在\",\n  \"data\": null\n}"
            },
            {
              "name": "必填欄位缺少",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 422,\n  \"msg\": \"帳號為必填\",\n  \"data\": null\n}"
            }
          ]
        },
        {
          "name": "取得單一會員資料",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/members/1",
              "host": ["{{base_url}}"],
              "path": ["members", "1"]
            },
            "description": "依 ID 取得會員資料。**需要登入 Token**\n\n注意：回傳不含密碼、不含存款（balance 為後台專用欄位）"
          },
          "response": [
            {
              "name": "成功",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 200,\n  \"msg\": \"success\",\n  \"data\": {\n    \"id\": 1,\n    \"account\": \"testuser\",\n    \"avatar\": \"/uploads/avatar/20260324/abc123.jpg\",\n    \"nickname\": \"測試用戶\",\n    \"email\": \"test@example.com\",\n    \"phone\": \"0912345678\",\n    \"is_active\": 1,\n    \"created_at\": \"2026-03-24T00:00:00.000000Z\"\n  }\n}"
            },
            {
              "name": "會員不存在",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 404,\n  \"msg\": \"會員不存在\",\n  \"data\": null\n}"
            },
            {
              "name": "未帶 Token",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 401,\n  \"msg\": \"請先登入\"\n}"
            }
          ]
        },
        {
          "name": "查詢會員流水記錄",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/members/1/transactions?page=1",
              "host": ["{{base_url}}"],
              "path": ["members", "1", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "頁碼（選填，預設第 1 頁，每頁 15 筆）"
                }
              ]
            },
            "description": "查詢指定會員的存款流水記錄。**需要登入 Token**\n\n- 依時間新到舊排序\n- 每頁 15 筆，支援分頁\n- 類型：1 = 增加、2 = 減少"
          },
          "response": [
            {
              "name": "成功",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 200,\n  \"msg\": \"success\",\n  \"data\": [\n    {\n      \"id\": 10,\n      \"type\": 1,\n      \"amount\": \"500.00\",\n      \"before_balance\": \"1000.00\",\n      \"after_balance\": \"1500.00\",\n      \"remark\": \"人工充值\",\n      \"created_at\": \"2026-03-24T12:00:00.000000Z\"\n    },\n    {\n      \"id\": 9,\n      \"type\": 2,\n      \"amount\": \"200.00\",\n      \"before_balance\": \"1200.00\",\n      \"after_balance\": \"1000.00\",\n      \"remark\": null,\n      \"created_at\": \"2026-03-23T09:30:00.000000Z\"\n    }\n  ],\n  \"meta\": {\n    \"current_page\": 1,\n    \"last_page\": 3,\n    \"per_page\": 15,\n    \"total\": 42\n  }\n}"
            },
            {
              "name": "會員不存在",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 404,\n  \"msg\": \"會員不存在\",\n  \"data\": null\n}"
            },
            {
              "name": "未帶 Token",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"code\": 401,\n  \"msg\": \"請先登入\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "系統",
      "item": [
        {
          "name": "設定 Callback URL",
          "request": {
            "method": "POST",
            "header": [
